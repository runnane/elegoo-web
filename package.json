{
  "name": "elegoo-web",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "concurrently -n svc,web -c magenta,cyan \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:web": "vite",
    "dev:service": "tsx watch src/server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "service": "tsx src/server/index.ts",
    "service:check": "tsc --project tsconfig.server.json",
    "service:install": "sudo bash contrib/install.sh",
    "service:uninstall": "sudo bash contrib/uninstall.sh",
    "service:restart": "sudo systemctl restart elegooweb",
    "service:stop": "sudo systemctl stop elegooweb",
    "service:logs": "sudo journalctl -u elegooweb -f",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "docker:build": "docker build -t ghcr.io/runnane/elegoo-web:local .",
    "docker:push": "docker push ghcr.io/runnane/elegoo-web:local",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "eslint src/ --fix && prettier --write src/",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/pdfkit": "^0.17.5",
    "@types/three": "0.178.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "release-it": "^19.2.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "gcode-preview": "3.0.0-alpha.4",
    "grammy": "^1.35.0",
    "mqtt": "^5.10.0",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "three": "0.178.0",
    "tsx": "^4.19.0",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.24.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "updateConfig": {
      "ignoreDependencies": [
        "three",
        "@types/three"
      ]
    }
  }
}
