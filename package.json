{
  "name": "elegoo-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n svc,web -c magenta,cyan \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:web": "vite",
    "dev:service": "tsx watch src/server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "service": "tsx src/server/index.ts",
    "service:check": "tsc --project tsconfig.server.json",
    "service:install": "sudo bash contrib/install.sh",
    "service:uninstall": "sudo bash contrib/uninstall.sh",
    "service:restart": "sudo systemctl restart elegoo-web",
    "service:stop": "sudo systemctl stop elegoo-web",
    "service:logs": "sudo journalctl -u elegoo-web -f"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.5",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.35.0",
    "mqtt": "^5.10.0",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
