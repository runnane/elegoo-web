{
  "name": "elegoo-web",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "simple-git-hooks": {
    "pre-commit": "pnpm exec biome check --staged --write --no-errors-on-unmatched"
  },
  "scripts": {
    "dev": "concurrently -n svc,web -c magenta,cyan \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:web": "vite",
    "dev:service": "tsx watch src/server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "service": "tsx src/server/index.ts",
    "service:check": "tsc --project tsconfig.server.json",
    "service:install": "sudo bash contrib/install.sh",
    "service:uninstall": "sudo bash contrib/uninstall.sh",
    "service:restart": "sudo systemctl restart elegooweb",
    "service:stop": "sudo systemctl stop elegooweb",
    "service:logs": "sudo journalctl -u elegooweb -f",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "docker:build": "docker build -t ghcr.io/runnane/elegoo-web:local .",
    "docker:push": "docker push ghcr.io/runnane/elegoo-web:local",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "biome check --write src/",
    "prepare": "simple-git-hooks || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/pdfkit": "^0.17.5",
    "@types/three": "0.184.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.0",
    "release-it": "^19.2.4",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "gcode-preview": "3.0.0-alpha.4",
    "grammy": "^1.35.0",
    "mqtt": "^5.10.0",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "three": "0.184.0",
    "tsx": "^4.19.0",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.24.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "updateConfig": {
      "ignoreDependencies": [
        "three",
        "@types/three"
      ]
    }
  }
}
